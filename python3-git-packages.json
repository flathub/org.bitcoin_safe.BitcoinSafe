{
    "name": "python3-git-packages",
    "buildsystem": "simple",
    "build-options": {
        "env": {
            "PIP_CONFIG_FILE": "/dev/null",
            "PIP_DISABLE_PIP_VERSION_CHECK": "1",
            "PIP_NO_INDEX": "1",
            "PIP_FIND_LINKS": "/app/share/bitcoin-safe/vendor/build-backends"
        }
    },
    "build-commands": [
        "python3 -m pip install --ignore-installed --no-dependencies --no-warn-script-location --no-compile --prefix=/app _vendor/git-packages/*"
    ],
